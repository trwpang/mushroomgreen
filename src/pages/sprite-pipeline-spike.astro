---
/**
 * Spike — generated sprite pipeline gallery.
 *
 * Local audit page for raw AI sprite output -> chroma-key removal -> trimmed
 * transparent PNGs -> manifest data. The processed PNGs live under ignored
 * public/sprite-map/generated, so run `npm run sprites:pipeline` first.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import manifest from '../data/generated-sprite-manifest.json';
---

<BaseLayout title="Sprite Pipeline Spike — Mushroom Green">
  <main>
    <header>
      <p>Sprite pipeline spike</p>
      <h1>AI sprite outputs, keyed and manifest-ready</h1>
      <dl>
        <div><dt>Input</dt><dd>{manifest.input}</dd></div>
        <div><dt>Output</dt><dd>{manifest.output}</dd></div>
        <div><dt>Sprites</dt><dd>{manifest.sprites.length}</dd></div>
        <div><dt>Rejected</dt><dd>{manifest.audit?.rejectedCount ?? 0}</dd></div>
      </dl>
    </header>

    <section class="sprite-grid" aria-label="Generated sprites">
      {manifest.sprites.map((sprite) => (
        <article class:list={[sprite.status === 'rejected' ? 'rejected' : sprite.warnings?.length ? 'warn' : '']}>
          <div class="preview">
            <img src={sprite.url} alt="" loading="lazy" />
          </div>
          <h2>{sprite.key}</h2>
          <p>{sprite.width} x {sprite.height} px · anchor {sprite.anchorX}, {sprite.anchorY}</p>
          <p class="meta">{sprite.category ?? 'uncategorized'} · {sprite.status ?? 'accepted'}</p>
          {sprite.warnings?.length > 0 && (
            <ul>
              {sprite.warnings.map((warning) => <li>{warning}</li>)}
            </ul>
          )}
          <code>{sprite.source}</code>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #f6efd8;
  }

  main {
    min-height: 100vh;
    color: #24170f;
  }

  header {
    padding: 34px clamp(18px, 4vw, 56px) 26px;
    background: #fff8de;
    border-bottom: 1px solid rgba(99, 68, 38, 0.22);
  }

  header p {
    font: 700 0.76rem/1.1 system-ui, sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #76552f;
  }

  h1 {
    margin-top: 8px;
    max-width: 880px;
    font-size: clamp(2rem, 5vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    max-width: 980px;
    margin-top: 24px;
  }

  dl div {
    min-width: 0;
    padding-top: 10px;
    border-top: 1px solid rgba(99, 68, 38, 0.22);
  }

  dt {
    font: 700 0.7rem/1 system-ui, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #806346;
  }

  dd {
    margin-top: 6px;
    overflow-wrap: anywhere;
    font: 0.92rem/1.3 system-ui, sans-serif;
  }

  .sprite-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 14px;
    padding: clamp(18px, 4vw, 56px);
  }

  article {
    overflow: hidden;
    background: #fffaf0;
    border: 1px solid rgba(99, 68, 38, 0.2);
    border-radius: 8px;
  }

  article.warn {
    border-color: rgba(150, 58, 30, 0.5);
    box-shadow: inset 0 0 0 2px rgba(150, 58, 30, 0.08);
  }

  article.rejected {
    opacity: 0.72;
    border-color: rgba(120, 30, 20, 0.72);
    box-shadow: inset 0 0 0 2px rgba(120, 30, 20, 0.16);
  }

  .preview {
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    background-color: #d8cba9;
    background-image:
      linear-gradient(45deg, rgba(255,255,255,0.42) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(255,255,255,0.42) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(255,255,255,0.42) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255,255,255,0.42) 75%);
    background-position: 0 0, 0 12px, 12px -12px, -12px 0;
    background-size: 24px 24px;
  }

  img {
    width: min(76%, 220px);
    height: min(76%, 220px);
    object-fit: contain;
    filter: drop-shadow(8px 12px 0 rgba(44, 32, 20, 0.18));
  }

  h2,
  article p,
  code {
    margin-inline: 12px;
  }

  h2 {
    margin-top: 12px;
    font: 700 0.96rem/1.2 system-ui, sans-serif;
    overflow-wrap: anywhere;
  }

  article p {
    margin-top: 5px;
    color: #604a34;
    font: 0.8rem/1.35 system-ui, sans-serif;
  }

  .meta {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.68rem;
    color: #7b603f;
  }

  ul {
    margin: 8px 12px 0;
    padding: 7px 9px;
    list-style: none;
    border-radius: 6px;
    background: #f5dfcf;
    color: #742f1d;
    font: 700 0.68rem/1.35 system-ui, sans-serif;
  }

  code {
    display: block;
    margin-top: 9px;
    margin-bottom: 12px;
    color: #806346;
    font-size: 0.72rem;
    line-height: 1.35;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  @media (max-width: 680px) {
    dl {
      grid-template-columns: 1fr;
    }
  }
</style>
