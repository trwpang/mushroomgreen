---
import BaseLayout from '../layouts/BaseLayout.astro';

const sceneData = {
  clusters: [],
  brook: [],
  roads: [],
  boundary: [],
};
---

<BaseLayout title="Phaser Spike — Mushroom Green">
  <div id="phaser-root" style="width:100vw;height:100vh;"></div>
  <script
    type="application/json"
    id="scene-data"
    set:html={JSON.stringify(sceneData)}
  />
  <script>
    import '../scripts/phaser-scene.ts';
  </script>
</BaseLayout>

<style>
  :global(body) {
    margin: 0;
    overflow: hidden;
  }
</style>
