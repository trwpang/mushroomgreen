---
/**
 * Homepage — the Mushroom Green 1865 map.
 *
 * Wraps <VillageMap /> with the dark-brown header (title + family-colour
 * legend, lifted from legacy/Map/mushroom_green_1865_v10_11_35_28.html lines
 * 47-67) and four fixed-position Victorian chrome components:
 * decorative outer border, title cartouche, scale-of-chains, and the
 * "Surveyed by Michael Weaver" attribution. Colours are pulled from
 * families.json so the legend stays in sync with the map polygons.
 *
 * Header is 72px (matches v10_11_35_28 line 12) — taller than v10_9_3's 48px
 * because the legend wraps onto two rows. The map's inline `height: calc(100vh
 * - 48px)` from VillageMap is overridden below via :global(#map) so we don't
 * need to touch VillageMap.astro for a chrome-only change.
 *
 * Print CSS preserved for A4-landscape handouts: shrinks the header to 36px,
 * overrides the map height accordingly, and hides the Victorian chrome
 * (border / cartouche / scale / attribution) so the print layout stays clean.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import VillageMap from '../components/VillageMap.astro';
import VictorianBorder from '../components/VictorianBorder.astro';
import VictorianTitleCartouche from '../components/VictorianTitleCartouche.astro';
import ScaleOfChains from '../components/ScaleOfChains.astro';
import SurveyedBy from '../components/SurveyedBy.astro';
import families from '../data/families.json';

// Legend order matches the legacy header. The Founder swatch leads, the nine
// family colours follow in legacy order, then Other, then the boundary swatch
// (rendered separately because it has no fill).
const legendFamilies: Array<{ key: keyof typeof families; label: string; textColor?: string }> = [
  { key: 'Founder',    label: '\u2605 Founder' },
  { key: 'Weaver',     label: 'Weaver' },
  { key: 'Billingham', label: 'Billingham' },
  { key: 'Hancox',     label: 'Hancox' },
  { key: 'Dimmock',    label: 'Dimmock' },
  { key: 'Griffiths',  label: 'Griffiths' },
  { key: 'Nicklin',    label: 'Nicklin' },
  { key: 'Pearson',    label: 'Pearson' },
  { key: 'Sidaway',    label: 'Sidaway' },
  { key: 'Kendrick',   label: 'Kendrick' },
  // Legacy uses #e8e0cc for the "Other" label text (the fill #f0ece0 is too
  // pale to read on the dark header). Keep that override.
  { key: 'Other',      label: 'Other', textColor: '#e8e0cc' },
];
---
<BaseLayout title="Mushroom Green — 1865 Occupants">
  <div id="header">
    <div>
      <h1>Mushroom Green &mdash; 1865 Occupants</h1>
      <p>Book of Weaver &middot; OSM mapping by Mike Mushroom &middot; 59 households &middot; Click any house for details</p>
    </div>
    <div id="legend">
      {legendFamilies.map(({ key, label, textColor }) => {
        const swatch = families[key];
        const borderWidth = key === 'Founder' ? 2 : key === 'Other' ? 1 : 1.5;
        return (
          <div class="li">
            <div class="lb" style={`background:${swatch.fill};border:${borderWidth}px solid ${swatch.border};`}></div>
            <span style={`color:${textColor ?? swatch.fill}`}>{label}</span>
          </div>
        );
      })}
      <div class="li">
        <div class="lbd"></div>
        <span style="color:#c8a87a">Boundary</span>
      </div>
    </div>
  </div>
  <VillageMap />
  <!--
    Stacking order matters: the border sits beneath the cartouche / scale /
    attribution so its inset shadow layers don't cut into them. All four are
    `pointer-events: none` so the map underneath stays interactable.
  -->
  <VictorianBorder />
  <VictorianTitleCartouche />
  <ScaleOfChains />
  <SurveyedBy />
</BaseLayout>

<style>
  /* Header — lifted from legacy v10_11_35_28 lines 11-17. */
  #header {
    background: #2c1810;
    color: #f5e6c8;
    padding: 12px 16px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid #803303;
  }
  #header h1 {
    font-size: 1.2em;
    letter-spacing: 0.03em;
  }
  #header p {
    font-size: 0.8em;
    color: #c8a87a;
    margin-top: 1px;
  }

  /*
   * Override the map's inline `height: calc(100vh - 48px)` from
   * VillageMap.astro now that the header is 72px. Done here (not in
   * VillageMap) so the map component stays unchanged for this chrome-only
   * change.
   */
  :global(#map) {
    height: calc(100vh - 72px);
  }

  /* Legend swatches — lifted from legacy lines 19-22. */
  #legend {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 0.7em;
    flex-shrink: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
    max-width: 55%;
  }
  .li {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .lb {
    width: 13px;
    height: 9px;
    border-radius: 2px;
  }
  .lbd {
    width: 13px;
    height: 9px;
    border-radius: 2px;
    border: 2px dashed #803303;
  }

  /*
   * body margin reset / font-family / background all live in global.css now —
   * removed the local :global(body) overrides that previously forced Georgia
   * and would have defeated the IM Fell English wiring from BaseLayout.
   */

  /* Print CSS — A4-landscape handouts. Shrinks the header to 36px and
     overrides the runtime `:global(#map)` height above. */
  @media print {
    :global(body) { background: #fff; }
    #header {
      background: #2c1810 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      height: 36px;
      padding: 5px 12px;
    }
    :global(#map) {
      height: calc(100vh - 36px) !important;
    }
  }
</style>
