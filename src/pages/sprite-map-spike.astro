---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import clusters from '../data/clusters.json';
import boundary from '../data/boundary.json';
import brook from '../data/brook.json';
import roads from '../data/roads.json';
import manifest from '../data/generated-sprite-manifest.json';
import overrides from '../data/sprite-map-overrides.json';

const households = await getCollection('households');
const byNumber: Record<string, { id: string; name: string }> =
  Object.fromEntries(households.map((h) => [
    String(h.data.number),
    { id: h.id, name: h.data.household_name },
  ]));
---

<BaseLayout title="Sprite Map Spike — Mushroom Green">
  <main id="sprite-map-shell">
    <section id="sprite-map-stage" aria-label="Generated sprite map prototype"></section>
    <aside id="sprite-map-panel">
      <p>Generated sprite map</p>
      <h1>Real clusters, imagegen sprites</h1>
      <dl>
        <div><dt>Sprite source</dt><dd>{manifest.sprites.length} processed assets</dd></div>
        <div><dt>Water</dt><dd>Blue sprite brook</dd></div>
        <div><dt>Engine</dt><dd>Phaser scene, manifest-driven</dd></div>
      </dl>
    </aside>
    <div id="sprite-map-tooltip" hidden></div>
    <div id="sprite-map-popup" hidden></div>
  </main>

  <script
    type="application/json"
    id="sprite-map-data"
    set:html={JSON.stringify({
      clusters: clusters.clusters,
      boundary,
      brook,
      roads,
      byNumber,
      manifest,
      overrides,
    })}
  />
  <script>
    import '../scripts/sprite-map-spike.ts';
  </script>
</BaseLayout>

<style>
  :global(body) {
    margin: 0;
    overflow: hidden;
    background: #f4ead0;
  }

  #sprite-map-shell,
  #sprite-map-stage {
    position: relative;
    width: 100vw;
    height: 100vh;
  }

  #sprite-map-shell {
    background: linear-gradient(180deg, #cae0db, #f7eed4);
  }

  #sprite-map-panel {
    position: absolute;
    top: 20px;
    left: 20px;
    width: min(360px, calc(100vw - 40px));
    padding: 16px 17px;
    color: #29190f;
    background: rgba(255, 250, 230, 0.82);
    border: 1px solid rgba(112, 78, 43, 0.22);
    border-radius: 8px;
    box-shadow: 0 16px 48px rgba(60, 45, 25, 0.18);
    backdrop-filter: blur(12px);
    pointer-events: none;
  }

  #sprite-map-panel p {
    font: 700 0.72rem/1.1 system-ui, sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #795732;
  }

  #sprite-map-panel h1 {
    margin-top: 7px;
    font-size: clamp(1.8rem, 4vw, 3.35rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  #sprite-map-panel dl {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 16px;
  }

  #sprite-map-panel dl div {
    min-width: 0;
    padding-top: 9px;
    border-top: 1px solid rgba(112, 78, 43, 0.24);
  }

  #sprite-map-panel dt {
    font: 700 0.62rem/1 system-ui, sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #866746;
  }

  #sprite-map-panel dd {
    margin-top: 5px;
    font: 0.78rem/1.25 system-ui, sans-serif;
  }

  :global(#sprite-map-tooltip),
  :global(#sprite-map-popup) {
    position: fixed;
    z-index: 10;
    background: #2c1810;
    color: #fff7df;
    font-family: system-ui, sans-serif;
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.28);
  }

  :global(#sprite-map-tooltip) {
    pointer-events: none;
    max-width: 280px;
    padding: 8px 10px;
    border-radius: 5px;
    font-size: 0.82rem;
    line-height: 1.35;
    white-space: pre-line;
  }

  :global(#sprite-map-popup) {
    min-width: 230px;
    max-width: min(320px, calc(100vw - 28px));
    padding: 14px 16px;
    border-radius: 8px;
  }

  :global(#sprite-map-popup h2) {
    margin: 0 0 8px;
    font-size: 0.94rem;
    line-height: 1.25;
  }

  :global(#sprite-map-popup ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  :global(#sprite-map-popup li) {
    padding: 4px 0;
    font-size: 0.86rem;
  }

  :global(#sprite-map-popup a) {
    color: #fff7df;
    text-decoration: none;
    border-bottom: 1px dotted rgba(255, 247, 223, 0.6);
  }

  @media (max-width: 720px) {
    #sprite-map-panel {
      top: 10px;
      left: 10px;
      width: calc(100vw - 20px);
      padding: 12px;
    }

    #sprite-map-panel h1 {
      font-size: 1.65rem;
    }

    #sprite-map-panel dl {
      display: none;
    }
  }
</style>
