---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import families from '../../data/families.json';

export async function getStaticPaths() {
  const households = await getCollection('households');
  return households.map((h) => ({ params: { id: h.id }, props: { h } }));
}

interface Props { h: CollectionEntry<'households'>; } const { h } = Astro.props;
const d = h.data;
const name = d.household_name;
const lat = d.position.lat;
const lon = d.position.lon;
const swatch = d.founder ? families.Founder : families[d.family] ?? families.Other;

const allHouseholds = await getCollection('households');
const byNumber = Object.fromEntries(allHouseholds.map((x) => [x.data.number, x]));
const neighbours = (d.neighbours ?? []).map((n) => byNumber[n]).filter(Boolean);

const mapScript = `
const household = ${JSON.stringify({
  lat, lon, polygon: d.polygon, fillColor: swatch.fill, borderColor: swatch.border,
})};
const map = L.map('household-map', { zoomControl: true, scrollWheelZoom: false });
L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
  attribution: '&copy; OpenStreetMap &copy; CARTO', subdomains: 'abcd', maxZoom: 21,
}).addTo(map);
const markerLatLng = [household.lat, household.lon];
if (household.polygon && household.polygon.length > 2) {
  const polygon = L.polygon(household.polygon, {
    fillColor: household.fillColor, fillOpacity: 0.72,
    color: household.borderColor, weight: 2,
  }).addTo(map);
  map.fitBounds(polygon.getBounds(), { padding: [24, 24], maxZoom: 20 });
} else {
  map.setView(markerLatLng, 16);
}
L.marker(markerLatLng).addTo(map);
`;
---

<BaseLayout title={`${name} — Mushroomgreen`}>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js" is:inline></script>

  <header class="top-strip">
    <nav>
      <a href="/">&#8592; Back to the map</a>
      <a href="/phaser-spike">&#8592; Back to the painted village</a>
    </nav>
  </header>

  <main>
    <article class="card">
      <p class="eyebrow">Household {d.number}</p>
      <div class="title-row">
        <h1>{name}</h1>
        <span class="family-badge" style={`background:${swatch.fill};border-color:${swatch.border};`}>
          {d.family}
        </span>
      </div>

      <div class="notices">
        {d.founder && <span class="founder">&#9733; Founder</span>}
        {d.estimated_position && <span class="estimated">Position estimated</span>}
      </div>

      <section class="facts" aria-label="Household facts">
        <dl>
          <div><dt>Occupants in 1861</dt><dd>{d.occupants_1861}</dd></div>
          <div><dt>Coordinates</dt><dd>{lat.toFixed(5)}, {lon.toFixed(5)}</dd></div>
        </dl>
      </section>

      <section>
        <h2>Sources</h2>
        <ul>{(d.sources ?? []).map((source) => <li>{source}</li>)}</ul>
      </section>

      {neighbours.length > 0 && (
        <section>
          <h2>Neighbours</h2>
          <ul>
            {neighbours.map((n) => (
              <li><a href={`/households/${n.id}/`}>{n.data.number}. {n.data.household_name}</a></li>
            ))}
          </ul>
        </section>
      )}

      <section>
        <h2>Map</h2>
        <div id="household-map" aria-label={`${name} household map`}></div>
      </section>
    </article>
  </main>

  <script is:inline set:html={mapScript}></script>
</BaseLayout>

<style>
  :global(body) {
    background: #ead7b2;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .top-strip {
    background: #2c1810;
    border-bottom: 2px solid #803303;
    color: #f5e6c8;
    padding: 14px 18px;
  }

  nav, .card { margin: 0 auto; max-width: 720px; }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
  }

  .top-strip a { color: #f5e6c8; text-decoration-color: #c8a87a; }
  main { padding: 28px 16px 42px; }

  .card {
    background: #f5e6c8;
    border: 2px solid #803303;
    box-shadow: 0 8px 24px rgba(44, 24, 16, 0.18);
    padding: 24px;
  }

  .eyebrow {
    color: #803303;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .title-row, .notices { display: flex; flex-wrap: wrap; gap: 10px 12px; }
  .title-row { align-items: center; margin-top: 4px; }
  .notices { margin-top: 14px; }

  h1 {
    color: #2c1810;
    font-family: "IM Fell English", Georgia, serif;
    font-size: clamp(2.25rem, 7vw, 4rem);
    font-weight: 400;
    line-height: 1;
  }

  h2 {
    border-bottom: 1px solid #c8a87a;
    color: #2c1810;
    font-size: 1rem;
    margin: 24px 0 10px;
    padding-bottom: 5px;
  }

  .family-badge, .founder, .estimated {
    border: 2px solid;
    border-radius: 999px;
    color: #2c1810;
    display: inline-flex;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 4px 10px;
  }

  .founder { background: #fff4a3; border-color: #b8860b; }
  .estimated { background: #fff3cd; border-color: #c07000; }
  .facts dl { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); margin-top: 22px; }
  .facts div { background: #fff8e8; border-left: 3px solid #803303; padding: 10px 12px; }
  dt { color: #6a4a32; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; }
  dd, li { font-size: 0.96rem; }
  ul { margin-left: 20px; }
  #household-map { background: #fff; border: 1px solid #c8a87a; height: 230px; margin-top: 10px; width: 100%; }
</style>
